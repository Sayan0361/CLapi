<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lumina Workbench</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
</head>
<body class="bg-black text-light vh-100 overflow-hidden pt-5">
    <div class="container-fluid h-100 p-0">
        <div class="row h-100 g-0">

            <aside class="col-lg-3 col-md-4 col-12 border-end border-secondary border-opacity-50 p-3 d-flex flex-column overflow-auto bg-black">

                <div class="d-flex justify-content-between align-items-start mb-5">
                    <div class="d-flex align-items-center gap-3">
                        <div class="p-2 rounded bg-dark border border-secondary border-opacity-50">
                            <i class="bi bi-activity text-primary fs-5"></i>                    
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold">CLapi</h6>
                            <small class="text-secondary">CLapi.com</small>
                        </div>
                    </div>
                    <button class="btn btn-sm text-secondary pe-0">
                        <i class="bi bi-box-arrow-right fs-5"></i>
                    </button>
                </div>

                <div class="text-uppercase text-secondary small fw-bold mb-3 d-flex align-items-center gap-2">
                    <i class="bi bi-layers"></i> COLLECTIONS
                </div>

                <div class="accordion flex-grow-1" id="collectionsAccordion">
                    
                    <div class="accordion-item bg-transparent border-0 mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-transparent text-light shadow-none p-2 collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collection1">
                                <i class="bi bi-circle-fill text-secondary me-2" style="font-size: 0.4rem;"></i> Authentication
                            </button>
                        </h2>
                        <div id="collection1" class="accordion-collapse collapse">
                            <div class="accordion-body p-0 ms-4">
                                <div class="list-group list-group-flush border-start border-secondary border-opacity-50 ps-2">
                                    <button class="list-group-item list-group-item-action bg-transparent text-secondary border-0 p-1 small">
                                        <i class="bi bi-clock me-1"></i> 01/01/2024
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="accordion-item bg-transparent border-0 mb-2">
                        <h2 class="accordion-header">
                            <button class="accordion-button bg-transparent text-light shadow-none p-2 collapsed"
                                    data-bs-toggle="collapse"
                                    data-bs-target="#collection2">
                                <i class="bi bi-circle-fill text-secondary me-2" style="font-size: 0.4rem;"></i> Data Processing
                            </button>
                        </h2>
                        <div id="collection2" class="accordion-collapse collapse">
                            <div class="accordion-body p-0 ms-4">
                                <div class="list-group list-group-flush border-start border-secondary border-opacity-50 ps-2">
                                    <button class="list-group-item list-group-item-action bg-transparent text-secondary border-0 p-1 small">
                                        <i class="bi bi-clock me-1"></i> 05/01/2024
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>

            </aside>


            <main class="col-lg-5 col-md-8 col-12 border-end border-secondary border-opacity-50 p-4 d-flex flex-column overflow-auto" style="background-color: #0b0c10;">

                <h5 class="mb-4 fw-bold"><i class="bi bi-code-slash me-2"></i> Configure tbl_Request</h5>

                <div class="d-flex gap-3 mb-3">
                    <select class="form-select w-auto bg-dark text-success fw-bold border-secondary shadow-none">
                        <option>GET</option>
                        <option>POST</option>
                        <option>PUT</option>
                        <option>DELETE</option>
                    </select>

                    <div class="input-group">
                        <span class="input-group-text bg-dark border-secondary border-end-0 text-secondary">
                            <i class="bi bi-hdd-stack"></i>
                        </span>
                        <input type="text"
                               class="form-control bg-dark text-light border-secondary border-start-0 shadow-none font-monospace"
                               value="https://api.lumina.io/v1/health">
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mb-5">
                    <button class="btn btn-outline-secondary text-light">
                        <i class="bi bi-floppy me-1"></i> Save to Collections
                    </button>
                    <button class="btn btn-primary px-4 fw-bold">
                        <i class="bi bi-send me-1"></i> Execute
                    </button>
                </div>

                <div class="d-flex justify-content-between text-secondary mb-2 small fw-bold">
                    <span class="text-uppercase">Request</span>
                    <span>JSON</span>
                </div>

                <div class="d-flex flex-grow-1 border border-secondary border-opacity-50 rounded bg-dark overflow-hidden mb-3">
                    <div class="bg-black text-secondary py-3 px-3 text-end font-monospace border-end border-secondary border-opacity-50 user-select-none d-flex flex-column gap-1 opacity-50 small">
                        <span>1</span><span>2</span><span>3</span><span>4</span><span>5</span><span>6</span><span>7</span><span>8</span><span>9</span><span>10</span>
                    </div>
                    <textarea class="form-control bg-transparent text-light border-0 shadow-none font-monospace p-3 pt-3" rows="12">{
  "ping": true
}</textarea>
                </div>

            </main>


            <aside class="col-lg-4 d-none d-lg-flex flex-column p-4" style="background-color: #0b0c10;">

                <h5 class="mb-5 fw-bold"><i class="bi bi-terminal me-2"></i> Response Inspector</h5>

                <div class="text-secondary small fw-bold text-uppercase mb-3">Response Output</div>
                
                <div class="flex-grow-1 border border-secondary border-opacity-50 rounded bg-black d-flex flex-column align-items-center justify-content-center text-center p-4 mb-3">
                    
                    <i class="bi bi-server fs-1 text-secondary opacity-25 mb-3"></i>
                    
                    <h5 class="text-secondary mb-2">No Response Data</h5>
                    
                    <p class="text-secondary opacity-75 small px-4">
                        Execute the request to populate the 
                        <span class="badge bg-dark border border-secondary text-light rounded-1">response</span> 
                        and 
                        <span class="badge bg-dark border border-secondary text-light rounded-1">statusCode</span> 
                        .
                    </p>

                </div>
               
            </aside>

        </div>
    </div>
    
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

