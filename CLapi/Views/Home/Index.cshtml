<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

<body class="bg-dark text-light">

<div class="container-fluid vh-100">
    <div class="row h-100">

        <!-- SIDEBAR -->
        <aside class="col-lg-3 col-md-4 col-12 border-end p-3 bg-black overflow-auto">

            <div class="d-flex justify-content-between align-items-center mb-4">
                <div class="d-flex align-items-center gap-2">
                    <div class="p-2 rounded bg-primary bg-opacity-10 border border-primary border-opacity-25">
                        <i class="bi bi-feather"></i>                    
                    </div>
                    <div>
                        <h6 class="mb-0">CLapi Workbench</h6>
                        <small class="text-secondary">clapi.com</small>
                    </div>
                </div>

                <button class="btn btn-sm btn-outline-danger">
                    <i class="bi bi-box-arrow-right"></i>
                </button>
            </div>

            <h6 class="text-uppercase text-secondary small">tbl_Collections</h6>

            <div class="accordion" id="collectionsAccordion">

                <div class="accordion-item bg-dark text-white border-secondary">
                    <h2 class="accordion-header">
                        <button class="accordion-button bg-dark text-white collapsed"
                                data-bs-toggle="collapse"
                                data-bs-target="#collection1">
                            Collection 1
                        </button>
                    </h2>

                    <div id="collection1" class="accordion-collapse collapse">
                        <div class="accordion-body p-2">

                            <div class="list-group">
                                <button class="list-group-item list-group-item-action bg-dark text-white border-secondary">
                                    Request 1
                                </button>

                                <button class="list-group-item list-group-item-action bg-dark text-white border-secondary">
                                    Request 2
                                </button>
                            </div>

                        </div>
                    </div>
                </div>

                <div class="accordion-item bg-dark text-white border-secondary">
                    <h2 class="accordion-header">
                        <button class="accordion-button bg-dark text-white collapsed"
                                data-bs-toggle="collapse"
                                data-bs-target="#collection2">
                            Collection 2
                        </button>
                    </h2>

                    <div id="collection2" class="accordion-collapse collapse">
                        <div class="accordion-body p-2">

                            <div class="list-group">
                                <button class="list-group-item list-group-item-action bg-dark text-white border-secondary">
                                    Request A
                                </button>

                                <button class="list-group-item list-group-item-action bg-dark text-white border-secondary">
                                    Request B
                                </button>
                            </div>

                        </div>
                    </div>
                </div>

            </div>

        </aside>


        <!-- REQUEST PANEL -->
        <main class="col-lg-5 col-md-8 col-12 border-end p-4 overflow-auto">

            <h6 class="mb-4">Configure tbl_Request</h6>

            <div class="d-flex flex-wrap gap-2 mb-3">

                <select class="form-select w-auto bg-dark text-primary border-secondary">
                    <option>GET</option>
                    <option>POST</option>
                    <option>PUT</option>
                    <option>DELETE</option>
                </select>

                <input class="form-control bg-dark text-white border-secondary flex-grow-1"
                       placeholder="Enter request URL">

            </div>

            <div class="d-flex justify-content-end gap-2 mb-4">
                <button class="btn btn-secondary btn-sm">
                    Save to tbl_Collections
                </button>

                <button class="btn btn-primary">
                    Execute
                </button>
            </div>

            <div class="d-flex pt-5">
                <textarea class="form-control bg-black text-light border-secondary"
                rows="12">
                { "hello": true }
                </textarea>
            </div>

        </main>


        <!-- RESPONSE PANEL -->
        <aside class="col-lg-4 d-none d-lg-block p-4 bg-black overflow-auto">

            <h6 class="mb-4">Response Inspector</h6>

            <div class="border rounded p-4 bg-dark text-center text-secondary h-100 d-flex align-items-center justify-content-center">
                No Response Data
            </div>

        </aside>

    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

</body>


