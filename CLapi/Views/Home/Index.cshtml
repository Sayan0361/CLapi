@model CLapi.Models.Collection_MessageModel

@{var groupedData = Model.collections.GroupBy(x => x.collectionId);}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>CLapi Workbench</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/prismjs/themes/prism-tomorrow.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/prismjs/prism.js"></script>
    <link rel="stylesheet" href="~/Content/index.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs/loader.min.js"></script>
</head>
@Html.Partial("_SaveCollectionDialog")
<body>
    <!-- TITLE BAR -->
    <div id="titleBar">
        <div class="traffic-lights">
            <div class="tl tl-red"></div>
            <div class="tl tl-yellow"></div>
            <div class="tl tl-green"></div>
        </div>
        <div id="mobileSidebarBtn" title="Collections">
            <i class="bi bi-layout-sidebar"></i>
        </div>
        <div class="app-name" style="margin-left:4px;">CL<span>api</span> Workbench</div>
        <div class="title-spacer"></div>
        <div class="title-badge">v1.0.0</div>
    </div>

    <!-- SHELL -->
    <div class="shell" id="shell">

        <div id="sidebarToggle" title="Toggle sidebar">
            <i class="bi bi-layout-sidebar"></i>
        </div>

        <div id="sidebarOverlay"></div>

        <!-- LEFT SIDEBAR -->
        <aside id="collectionsPane">
            <div class="pane-header">
                <span class="pane-title">Collections</span>
                <div class="pane-action"><i class="bi bi-plus"></i></div>
            </div>

            <div class="collection-list">

                @foreach (var col in groupedData)
                {
                    var collectionName = col.First().collectionName;
                    <div class="collection-folder open">

                        <div class="col-section-label folder-header">
                            <i class="bi bi-chevron-down folder-icon"></i> @collectionName
                            <input type="hidden" value="@col.Key" />
                        </div>

                        <div class="folder-body">
                            @foreach (var req in col)
                            {
                                <div class="collection-item request-item"
                                     data-id="@req.reqId"
                                     data-name="@req.requestName"
                                     data-url="@req.requestURL"
                                     data-method-id="@req.methodId"
                                     data-method="@req.methodType"
                                     data-status="@req.statusCode"
                                     data-body="@req.body">

                                    <div class="method-dot"
                                         style="background:
                                @(req.methodType == "GET" ? "var(--method-get)" :
                                  req.methodType == "POST" ? "var(--method-post)" :
                                  req.methodType == "PUT" ? "var(--method-put)" :
                                  "var(--method-delete)")">
                                    </div>

                                    @req.requestName

                                </div>
                            }
                        </div>

                    </div>

                }

            </div>
            <div class="d-flex ms-auto text-danger p-3">
                    <i class="bi bi-box-arrow-right" id="logout_btn"></i>
            </div>

        </aside>

        <!-- MAIN PANEL -->
        <main id="mainPanel">

            <div class="request-header">
                <div class="section-label">Request</div>
                <div class="url-bar">
                    <select class="method-select active" id="methodSelect" style="color: #10B981;">
                        @*options will go here*@
                    </select>
                    <input type="text" class="url-input"
                           placeholder="https://api.example.com/v1/endpoint">
                    <div class="url-actions">
                        <div class="btn-icon" id="copyBtn" title="Copy URL" style="width:30px;height:30px;"><i class="bi bi-copy" style="font-size:11px;"></i></div>
                        <div class="btn-icon" id="paramsBtn" title="Params" style="width:30px;height:30px;"><i class="bi bi-sliders" style="font-size:11px;"></i></div>
                    </div>
                </div>
            </div>

            <div class="req-tabs">
                <div class="req-tab active">Body<span class="tab-badge"></span></div>
                <div class="req-tab">Headers</div>
                <div class="req-tab">Params</div>
                <div class="req-tab">Auth</div>
                <div class="req-tab">Pre-script</div>
            </div>

            <div class="body-editor-wrap">
                <div class="editor-toolbar">
                    <span class="editor-lang">JSON</span>
                    <div style="flex:1"></div>
                    <div class="btn-icon" title="Format" style="width:30px;height:30px;"><i class="bi bi-braces" style="font-size:11px;"></i></div>
                    <div class="btn-icon" title="Clear" style="width:30px;height:30px;"><i class="bi bi-trash3" style="font-size:11px;"></i></div>
                </div>
                <div class="editor-wrap">
                    <div class="editor-row" style="height:300px;">
                        <div id="codeEditor" style="width:100%;height:100%;"></div>
                    </div>
                </div>
            </div>

            <div class="action-bar">
                <button class="btn-send" id="sendBtn">
                    <i class="bi bi-send-fill"></i>
                    Send
                    <span class="kbd">⌘↵</span>
                </button>
                <button class="btn-outline" id="saveBtn">
                    <i class="bi bi-bookmark-plus"></i>
                    <span class="save-label">Save to Collection</span>
                </button>
                <div class="action-spacer"></div>
                <div class="action-bar-extra" style="display:flex;gap:6px;align-items:center;">
                    <div class="btn-icon" title="Environment"><i class="bi bi-globe2"></i></div>
                    <div class="btn-icon" title="Settings"><i class="bi bi-gear"></i></div>
                    <div class="status-pill" style="margin-left:4px;">
                        <div class="status-dot"></div>
                        <span>Ready</span>
                    </div>
                </div>
            </div>

        </main>

        <!-- RESPONSE INSPECTOR -->
        <aside id="responseInspector">
            <div id="dragHandle"></div>
            <div class="resp-header">
                <i class="bi bi-terminal" style="font-size:14px;color:var(--text-secondary);"></i>
                <span class="resp-title">Response</span>
                <div style="flex:1"></div>
                <div class="btn-icon" title="Copy" style="width:30px;height:30px;"><i class="bi bi-copy" style="font-size:11px;"></i></div>
                <div class="btn-icon" title="Download" style="width:30px;height:30px;"><i class="bi bi-download" style="font-size:11px;"></i></div>
            </div>
            <div class="resp-tabs">
                <div class="resp-tab active">Body</div>
                <div class="resp-tab">Headers</div>
                <div class="resp-tab">Console</div>
                <div class="resp-tab">Timeline</div>
            </div>
            <div class="resp-body" id="respBody">
                <div class="resp-empty-icon"><i class="bi bi-arrow-return-left"></i></div>
                <div class="resp-empty-text">
                    Hit <strong style="color:var(--text-secondary);">Send</strong> to see the response<br>
                    <span style="font-size:10px;">or press ⌘↵</span>
                </div>
            </div>
        </aside>

    </div>
    <!-- BOTTOM NAV -->
    <div id="bottomNav">
        <div class="bnav-tab active" data-panel="request">
            <i class="bi bi-code-slash"></i>Request
        </div>
        <div class="bnav-tab" data-panel="response">
            <i class="bi bi-terminal"></i>Response
        </div>
        <div class="bnav-tab" data-panel="collections">
            <i class="bi bi-collection"></i>Collections
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script>
        var editor;
        $(document).ready(function () {
            var data = @Html.Raw(Json.Encode(Model));
            var collections = data.collections;
            let userId = parseInt(localStorage.getItem("UserId"));
           $.ajax({
            url: '@Url.Action("Index", "Home")',
            type: 'GET',
            data: { UserId: userId },
            success: function (res) {
                console.log(res);
            }
        });

            $("#logout_btn").hover(
                function () {
                    $(this).css({
                        "opacity": "0.7",
                        "transform": "scale(1.1)"
                    });
                },
                function () {
                    $(this).css({
                        "opacity": "1",
                        "transform": "scale(1)"
                    });
                }
            );
            $("#logout_btn").on('click',function(){
                localStorage.clear();
                window.location.href = '@Url.Action("LogIn","Auth")';
            })

            /* ── Monaco Editor ── */
            

            require.config({ paths: { vs: 'https://cdnjs.cloudflare.com/ajax/libs/monaco-editor/0.45.0/min/vs' } });

            require(['vs/editor/editor.main'], function () {

                // Define a custom dark theme that matches your app palette
                monaco.editor.defineTheme('clapi-dark', {
                    base: 'vs-dark',
                    inherit: true,
                    rules: [
                        { token: 'string.key.json',   foreground: '7DD3FC' }, // keys  → sky blue
                        { token: 'string.value.json',  foreground: 'A3E635' }, // string values → lime
                        { token: 'number.json',        foreground: 'FB923C' }, // numbers → orange
                        { token: 'keyword.json',       foreground: 'F472B6' }, // true/false/null → pink
                        { token: 'delimiter.bracket',  foreground: '94A3B8' }, // {} [] → slate
                        { token: 'delimiter',          foreground: '64748B' }, // , : → muted
                    ],
                    colors: {
                        'editor.background':           '#0F1117',
                        'editor.foreground':           '#CBD5E1',
                        'editorLineNumber.foreground': '#334155',
                        'editorLineNumber.activeForeground': '#64748B',
                        'editor.lineHighlightBackground': '#1E293B55',
                        'editorCursor.foreground':     '#10B981',
                        'editor.selectionBackground':  '#10B98133',
                        'editorBracketMatch.background': '#10B98122',
                        'editorBracketMatch.border':   '#10B981',
                    }
                });

                editor = monaco.editor.create(document.getElementById('codeEditor'), {
                    value: '',
                    language: 'json',
                    theme: 'clapi-dark',
                    automaticLayout: true,
                    fontFamily: '"JetBrains Mono", monospace',
                    fontSize: 12,
                    lineHeight: 20,
                    minimap: { enabled: false },
                    scrollBeyondLastLine: false,
                    wordWrap: 'on',
                    renderLineHighlight: 'line',
                    cursorBlinking: 'smooth',
                    cursorSmoothCaretAnimation: 'on',
                    bracketPairColorization: { enabled: true },
                    formatOnPaste: true,
                    tabSize: 2,
                    scrollbar: {
                        verticalScrollbarSize: 4,
                        horizontalScrollbarSize: 4,
                    }
                });

                // Format button → Monaco built-in formatter
                $('.bi-braces').parent().on('click', function () {
                    editor.getAction('editor.action.formatDocument').run();
                });

                // Clear button
                $('.bi-trash3').parent().on('click', function () {
                    editor.setValue('');
                });

            });

            /* ── Collection item click ── */
            $('.request-item').on('click', function () {
                var url      = $(this).data("url");
                var method   = $(this).data("method");
                var methodid = $(this).data("method-id");
                var body     = $(this).data("body");

                let methodColor = methodIdToColor(methodid);
                $("#methodSelect").val(methodid).css('color', methodColor);
                $(".url-input").val(url);

                if (!body || body === "" || body === "null") {
                    if (editor) editor.setValue('');
                    return;
                }

                let parsed = body;
                if (typeof parsed === "string") {
                    try { parsed = JSON.parse(parsed); } catch { /* not JSON */ }
                }

                if (editor) {
                    const pretty = typeof parsed === 'object'
                        ? JSON.stringify(parsed, null, 2)
                        : String(parsed);
                    editor.setValue(pretty);
                    // Auto-format after setting
                    setTimeout(() => editor.getAction('editor.action.formatDocument').run(), 100);
                }
            });

            /* ── Helpers ── */
            function methodIdToColor(id) {
                if (id == 2) return '#F59E0B';
                if (id == 1) return '#10B981';
                if (id == 4) return '#EF4444';
                return '#3B82F6';
            }

            function getStatusText(code) {
                return ({ 200:'OK', 201:'Created', 204:'No Content',
                          400:'Bad Request', 401:'Unauthorized',
                          403:'Forbidden', 404:'Not Found',
                          500:'Internal Server Error' })[code] || 'Unknown';
            }

            function syntaxHighlight(json) {
                if (typeof json !== 'string') json = JSON.stringify(json, null, 2);
                json = json.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
                return json.replace(
                    /("(\\u[a-zA-Z0-9]{4}|\\[^u]|[^\\"])*"(\s*:)?|\b(true|false|null)\b|-?\d+(\.\d+)?)/g,
                    function (m) {
                        let cls = 'number';
                        if (/^"/.test(m)) cls = /:$/.test(m) ? 'key' : 'string';
                        else if (/true|false/.test(m)) cls = 'boolean';
                        else if (/null/.test(m)) cls = 'null';
                        return `<span class="${cls}">${m}</span>`;
                    }
                );
            }

            /* ── Sidebar ── */
            const isMobile   = () => window.innerWidth <= 768;
            const $sidebar   = $('#collectionsPane');
            const $overlay   = $('#sidebarOverlay');
            const $deskToggle = $('#sidebarToggle');
            const $mobToggle = $('#mobileSidebarBtn');
            const $mainPanel = $('#mainPanel');
            const $inspector = $('#responseInspector');
            const $methodSelect = $('#methodSelect');
            const $dragHandle = $('#dragHandle');
            const $bnavTabs  = $('.bnav-tab');
            const $reqUrl    = $('.url-input');

            function openSidebar()  { $sidebar.removeClass('collapsed'); if (isMobile()) $overlay.addClass('visible'); else $deskToggle.removeClass('sidebar-closed'); }
            function closeSidebar() { $sidebar.addClass('collapsed'); $overlay.removeClass('visible'); if (!isMobile()) $deskToggle.addClass('sidebar-closed'); }
            function toggleSidebar() { $sidebar.hasClass('collapsed') ? openSidebar() : closeSidebar(); }

            $deskToggle.on('click', toggleSidebar);
            $mobToggle.on('click', toggleSidebar);
            $overlay.on('click', closeSidebar);

            $(document).on('click', '.collection-item', function () {
                $('.collection-item').removeClass('active');
                $(this).addClass('active');
                if (isMobile()) closeSidebar();
            });

            $bnavTabs.on('click', function () {
                $bnavTabs.removeClass('active');
                $(this).addClass('active');
                const panel = $(this).data('panel');
                if (panel === 'collections') { openSidebar(); return; }
                closeSidebar();
                if (panel === 'request') { $mainPanel.css('display','flex'); $inspector.removeClass('mobile-visible'); }
                else { $mainPanel.css('display','none'); $inspector.addClass('mobile-visible'); }
            });

            $methodSelect.on('change', function () {
                $(this).css('color', methodIdToColor($(this).val()));
            });

            /* ── Drag resize ── */
            let dragging = false;
            $dragHandle.on('mousedown', () => { dragging = true; $('body').addClass('dragging'); });
            $(document).on('mousemove', function (e) {
                if (!dragging) return;
                const w = window.innerWidth - e.clientX;
                if (w > 260 && w < 800) $inspector.css('width', w + 'px');
            });
            $(document).on('mouseup', () => { dragging = false; $('body').removeClass('dragging'); });

            /* ── Tabs ── */
            $('.req-tab').on('click', function () { $('.req-tab').removeClass('active'); $(this).addClass('active'); });
            $('.resp-tab').on('click', function () { $('.resp-tab').removeClass('active'); $(this).addClass('active'); });

            /* ── Send ── */
            function doSend() {
                const bodyVal = editor ? editor.getValue() : '';

                // Show loading state
                $('#respBody').html(`
                    <div style="display:flex;align-items:center;justify-content:center;height:100%;gap:10px;color:var(--text-secondary);font-size:12px;font-family:'JetBrains Mono',monospace;">
                        <i class="bi bi-hourglass-split" style="animation:spin 1s linear infinite;"></i> Sending...
                    </div>
                `);

                $.ajax({
                    url: '@Url.Action("SendPostRequest", "Request")',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded',
                    data: {
                        RequestURL: $reqUrl.val(),
                        Body:       bodyVal,
                        MethodId:   parseInt($methodSelect.val()),
                        UserId:     localStorage.getItem("UserId"),
                        CollectionId: 1,
                        StatusCode: 200
                    },
                    success: function (response) {
                        console.log("Raw response:", response);

                        let displayData;
                        let status = 200;

                        try {
                            // If response is already an object (jQuery auto-parsed JSON)
                            if (typeof response === 'object' && response !== null) {
                                if (response.Body !== undefined) {
                                    try { displayData = JSON.parse(response.Body); }
                                    catch { displayData = response.Body; }
                                } else if (response.body !== undefined) {
                                    try { displayData = JSON.parse(response.body); }
                                    catch { displayData = response.body; }
                                } else if (response.data !== undefined) {
                                    displayData = response.data;
                                } else {
                                    displayData = response;
                                }
                                status = response.StatusCode || response.statusCode || response.status || 200;
                            }
                            // If response is a string
                            else if (typeof response === 'string') {
                                try { displayData = JSON.parse(response); }
                                catch { displayData = response; }
                                status = (displayData && (displayData.statusCode || displayData.StatusCode)) || 200;
                            } else {
                                displayData = response;
                            }
                        } catch(e) {
                            displayData = response;
                        }

                        // Resolve status from parsed data if not found at top level
                        if (displayData && typeof displayData === 'object') {
                            status = displayData.statusCode || displayData.StatusCode || displayData.status || status;
                        }

                        let statusText = getStatusText(status);
                        let color = status >= 500 ? '#ef4444' : status >= 400 ? '#ef4444' : status >= 300 ? '#f59e0b' : '#10b981';
                        let timeTaken = '—';

                        const highlighted = typeof displayData === 'object'
                            ? syntaxHighlight(JSON.stringify(displayData, null, 2))
                            : `<span style="color:#CBD5E1">${String(displayData)}</span>`;

                        $('#respBody').html(`
                            <div style="width:100%;height:100%;display:flex;flex-direction:column;overflow:hidden;">
                                <div style="padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;flex-shrink:0;">
                                    <span style="font-size:11px;font-weight:600;color:${color};background:${color}18;border:1px solid ${color}44;border-radius:5px;padding:2px 10px;font-family:'JetBrains Mono',monospace;">
                                        ${status} ${statusText}
                                    </span>
                                    <span style="font-size:10px;color:var(--text-secondary);margin-left:auto;">JSON</span>
                                </div>
                                <div style="flex:1;overflow:auto;padding:14px 16px;">
                                    <pre style="font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.8;white-space:pre-wrap;margin:0;">${highlighted}</pre>
                                </div>
                            </div>
                        `);
                    },
                    error: function (xhr, status, err) {
                        console.log("AJAX error:", xhr, status, err);

                        let errStatus = xhr.status || 0;
                        let errText = xhr.statusText || 'Request Failed';
                        let display;

                        // Try parsing JSON error
                        try {
                            const parsed = JSON.parse(xhr.responseText);

                            display = syntaxHighlight(JSON.stringify(parsed, null, 2));
                        }
                        catch {
                            // If NOT JSON (HTML or plain text)
                            let raw = xhr.responseText || '';

                            // Remove HTML tags if it's an error page
                            if (raw.includes("<html")) {
                                raw = "Server returned an HTML error page.\nCheck backend logs.";
                            }

                            display = `<span style="color:#CBD5E1">${raw || 'No response body'}</span>`;
                        }

                        $('#respBody').html(`
                            <div style="width:100%;height:100%;display:flex;flex-direction:column;overflow:hidden;">

                                <div style="padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px;">
                                    <span style="
                                        font-size:11px;
                                        font-weight:600;
                                        color:#ef4444;
                                        background:#ef444418;
                                        border:1px solid #ef444444;
                                        border-radius:5px;
                                        padding:2px 10px;
                                        font-family:'JetBrains Mono',monospace;">
                                        ${errStatus} ${errText}
                                    </span>
                                </div>

                                <div style="flex:1;overflow:auto;padding:14px 16px;">
                                    <pre style="font-family:'JetBrains Mono',monospace;font-size:12px;line-height:1.8;white-space:pre-wrap;margin:0;">
                                     ${display}
                                    </pre>
                                </div>

                            </div>
                        `);
                    }
                });
                
                if (isMobile()) {
                    $bnavTabs.removeClass('active');
                    $('[data-panel="response"]').addClass('active');
                    $mainPanel.css('display', 'none');
                    $inspector.addClass('mobile-visible');
                }
            }

            $('#sendBtn').on('click', doSend);
            $(document).on('keydown', function (e) { if ((e.metaKey || e.ctrlKey) && e.key === 'Enter') doSend(); });

            /* ── Save ── */
            $('#saveBtn').on('click', function () {
                const url      = $reqUrl.val().trim();
                const bodyVal  = editor ? editor.getValue() : '';
                const methodId = parseInt($methodSelect.val());

                if (!url) {
                    alert('Enter a URL before saving.');
                    return;
                }

                // Show saving state
                const $btn = $(this);
                $btn.prop('disabled', true)
                    .html('<i class="bi bi-hourglass-split"></i> Saving...');

                $.ajax({
                    url: '@Url.Action("SaveRequest", "Request")',
                    type: 'POST',
                    contentType: 'application/x-www-form-urlencoded',
                    data: {
                        RequestURL:   url,
                        Body:         bodyVal,
                        MethodId:     methodId,
                        CollectionId: 1,
                        UserId:       2,
                        RequestName:  url.split('/').pop() || 'New Request',
                        StatusCode:   200
                    },
                    success: function (response) {
                        console.log('Saved:', response);

                        // Add item to sidebar DOM
                        const name       = url.split('/').pop() || 'New Request';
                        const methodName = $methodSelect.find('option:selected').text();
                        const dotColor   = methodIdToColor(methodId);

                        const $item = $(`
                            <div class="collection-item request-item"
                                 data-url="${url}"
                                 data-method-id="${methodId}"
                                 data-method="${methodName}"
                                 data-body="${bodyVal.replace(/"/g, '&quot;')}">
                                <div class="method-dot" style="background:${dotColor}"></div>
                                ${name}
                            </div>
                        `);

                        // Append to first folder, or create a new one
                        let $target = $('.folder-body').first();
                        if ($target.length === 0) {
                            const $newFolder = $(`
                                <div class="collection-folder open">
                                    <div class="col-section-label folder-header">
                                        <i class="bi bi-chevron-down folder-icon"></i> My Collection
                                    </div>
                                    <div class="folder-body"></div>
                                </div>
                            `);
                            $('.collection-list').append($newFolder);
                            $target = $newFolder.find('.folder-body');
                        }
                        $target.append($item);

                        $btn.css({ background:'rgba(16,185,129,0.15)', borderColor:'#10b981', color:'#10b981' })
                            .html('<i class="bi bi-check2"></i> Saved!');
                    },
                    error: function (xhr) {
                        console.log('Save failed:', xhr);

                        $btn.css({ background:'rgba(239,68,68,0.15)', borderColor:'#ef4444', color:'#ef4444' })
                            .html('<i class="bi bi-x"></i> Failed');
                    },
                    complete: function () {
                        setTimeout(() => {
                            $btn.prop('disabled', false)
                                .attr('style', '')
                                .html('<i class="bi bi-bookmark-plus"></i><span class="save-label"> Save to Collection</span>');
                        }, 1800);
                    }
                });
            });

            /* ── Resize reset ── */
            $(window).on('resize', function () {
                if (!isMobile()) { $mainPanel.css('display','flex'); $inspector.removeClass('mobile-visible'); $overlay.removeClass('visible'); }
            });

            /* ── Accordion ── */
            $(document).on('click', '.folder-header', function () {
                const $f = $(this).parent();
                $f.hasClass('collapsed') ? $f.removeClass('collapsed').addClass('open') : $f.removeClass('open').addClass('collapsed');
            });

            /* ── Load Methods ── */
            $.ajax({
                url: '@Url.Action("GetMethods", "Home")',
                type: 'GET',
                success: function (response) {
                    response.methods.forEach(function (r) {
                        let color = r.MethodType === 'POST' ? '#F59E0B' : r.MethodType === 'GET' ? '#10B981' : r.MethodType === 'DELETE' ? '#EF4444' : '#3B82F6';
                        $methodSelect.append(`<option value="${r.MethodId}" style="color:${color}">${r.MethodType}</option>`);
                    });
                },
                error: function (r) { console.log('E: Methods:', r); }
            });

        });
    </script>

</body>
</html>