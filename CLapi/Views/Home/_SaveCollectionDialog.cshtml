<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>

<script>
    $(document).ready(function () {

        const $backdrop = $('#saveDialogBackdrop');
        const $dialog = $('#saveDialog');
        const $closeBtn = $('#sdlCloseBtn');
        const $cancelBtn = $('#sdlCancelBtn');
        const $saveBtn = $('#sdlSaveBtn');
        const $colSelect = $('#sdlCollectionSelect');
        const $reqName = $('#sdlReqName');
        const $toggleBtn = $('#sdlToggleNewCol');
        const $newColPanel = $('#sdlNewColPanel');
        const $newColName = $('#sdlNewColName');
        const $createColBtn = $('#sdlCreateColBtn');
        const $newColError = $('#sdlNewColError');

        var data = @Html.Raw(Json.Encode(Model));
        var collections = data.collections;
        console.log("data from PV: ",data)

        /* ── Populate collection dropdown from sidebar ───────────────── */
        function populateCollections() {
            $colSelect.find('option:not(:first)').remove();
            $('.collection-folder .folder-header').each(function () {
                const raw = $(this).clone();
                raw.find('i').remove();             // strip the chevron icon text
                const colID = raw.find('input').val();
                raw.find('input').remove();
                const name = raw.text().trim();
                if (name) $colSelect.append($('<option>', { value: name, text: name, id: colID }));
                console.log(colID)
            });
        }

        /* ── Toggle "New Collection" panel ──────────────────────────── */
        function openNewColPanel() {
            $toggleBtn.addClass('sdl-open');
            $newColPanel.addClass('sdl-panel-open');
            setTimeout(() => $newColName.focus(), 200);
        }

        function closeNewColPanel() {
            $toggleBtn.removeClass('sdl-open');
            $newColPanel.removeClass('sdl-panel-open');
            $newColName.val('');
            $newColError.text('').removeClass('sdl-error-visible');
        }

        $toggleBtn.on('click', function () {
            $newColPanel.hasClass('sdl-panel-open') ? closeNewColPanel() : openNewColPanel();
        });

        /* ── Create new collection ───────────────────────────────────── */
        function createCollection() {
            const name = $newColName.val().trim();

            if (!name) {
                $newColError.text('Please enter a collection name.').addClass('sdl-error-visible');
                $newColName.css('border-color', '#ef4444');
                setTimeout(() => $newColName.css('border-color', ''), 900);
                return;
            }

            // Check for duplicate name
            let isDuplicate = false;
            $colSelect.find('option').each(function () {
                if ($(this).val().toLowerCase() === name.toLowerCase()) { isDuplicate = true; }
            });

            if (isDuplicate) {
                $newColError.text('A collection with this name already exists.').addClass('sdl-error-visible');
                $newColName.css('border-color', '#ef4444');
                setTimeout(() => $newColName.css('border-color', ''), 900);
                return;
            }

            $.ajax({
                url: '@Url.Action("CreateNewCollection", "Request")',
                type: 'POST',
                data: {
                    collectionName: name,

                    UserId: localStorage.getItem("UserId")
                },
                success: function (response) {
                    console.log("S-Response: ", response);

                    // ── Add to sidebar immediately ──────────────────────────── */
                    const $newFolder = $(`
                            <div class="collection-folder open">
                                <div class="col-section-label folder-header">
                                    <i class="bi bi-chevron-down folder-icon"></i> ${name}
                                    <input type="hidden" value="${response.Data}" />
                                </div>
                                <div class="folder-body"></div>
                            </div>
                        `);
                    $('.collection-list').append($newFolder);

                    // ── Add to dropdown & auto-select it ─────────────────────── */
                    const $newOption = $('<option>', { value: name, text: name, class: 'sdl-just-created', id: response.Data });
                    $colSelect.append($newOption);
                    $colSelect.val(name);

                    // ── Visual feedback & collapse panel ─────────────────────── */
                    $createColBtn
                        .html('<i class="bi bi-check2"></i> Created!')
                        .css({ background: 'rgba(16,185,129,.25)', borderColor: '#10b981', pointerEvents: 'none' });

                    setTimeout(() => {
                        $createColBtn
                            .html('<i class="bi bi-plus"></i> Create')
                            .css({ background: '', borderColor: '', pointerEvents: '' });
                        closeNewColPanel();
                    }, 900);
                },
                error: function (response) {
                    console.log("E-Response: ", response);
                }
            })


        }

        $createColBtn.on('click', createCollection);

        $newColName.on('keydown', function (e) {
            if (e.key === 'Enter') { e.preventDefault(); createCollection(); }
        });

        // Clear error on input
        $newColName.on('input', function () {
            $newColError.text('').removeClass('sdl-error-visible');
            $(this).css('border-color', '');
        });

        /* ── Open dialog ─────────────────────────────────────────────── */
        function openDialog() {
            populateCollections();
            closeNewColPanel();

            const activeItemName = $('.collection-item.active').text().trim();
            const urlTail = $('.url-input').val().split('/').filter(Boolean).pop() || '';
            $reqName.val(activeItemName || urlTail || '');

            $backdrop.addClass('sdl-visible');
            $dialog.addClass('sdl-visible');
            setTimeout(() => $reqName.focus(), 240);
        }

        /* ── Close dialog ────────────────────────────────────────────── */
        function closeDialog() {
            $backdrop.removeClass('sdl-visible');
            $dialog.removeClass('sdl-visible');
            closeNewColPanel();
            $saveBtn.removeClass('sdl-saved').html('<i class="bi bi-check2"></i> Save');
        }

        /* ── Wire existing Save button ───────────────────────────────── */
        $('#saveBtn').off('click').on('click', function (e) {
            e.stopPropagation();
            openDialog();
        });

        /* ── Close triggers ──────────────────────────────────────────── */
        $closeBtn.on('click', closeDialog);
        $cancelBtn.on('click', closeDialog);
        $backdrop.on('click', closeDialog);
        $(document).on('keydown.saveDialog', function (e) {
            if (e.key === 'Escape' && $dialog.hasClass('sdl-visible')) closeDialog();
        });

        /* ── Confirm Save (add request to chosen collection) ─────────── */
        $saveBtn.on('click', function () {
            const collection = $colSelect.val();
            const name = $reqName.val().trim() || 'New Request';
            const method = $('#methodSelect').val();
            const url = $('.url-input').val();
            const reqBody = editor ? editor.getValue() : ''

            console.log(collection)

            const newColName = $newColName.val().trim();

            if (!collection) {
                $colSelect.css('border-color', '#ef4444');
                $colSelect[0].animate && $colSelect[0].animate(
                    [{ transform: 'translateX(-4px)' }, { transform: 'translateX(4px)' }, { transform: 'translateX(0)' }],
                    { duration: 250, iterations: 2 }
                );
                setTimeout(() => $colSelect.css('border-color', ''), 900);
                return;
            }

            /* Find folder in sidebar */
            let collectionId = 0;

            $('.collection-folder .folder-header').each(function () {
                const $clone = $(this).clone();
                $clone.find('i').remove();

                if ($clone.text().trim() === collection) {
                    $targetFolder = $(this).closest('.collection-folder');

                    collectionId = $(this).find('input[type="hidden"]').val();

                    console.log("CollectionId:", collectionId);
                }
            });

            if (!$targetFolder) {
                $targetFolder = $(`
                <div class="collection-folder open">
                    <div class="col-section-label folder-header">
                        <i class="bi bi-chevron-down folder-icon"></i> ${collection}
                        <input type="hidden" value="0"/>
                    </div>
                    <div class="folder-body"></div>
                </div>
            `);
                $('.collection-list').append($targetFolder);
            }

            const methodText = $('#methodSelect option:selected').text().trim();
            const methodColorMap = {
                'GET': 'var(--method-get)', 'POST': 'var(--method-post)',
                'PUT': 'var(--method-put)', 'DELETE': 'var(--method-delete)'
            };
            const dotColor = methodColorMap[methodText] || 'var(--method-get)';

            // 1. Append UI
            $targetFolder.find('.folder-body').append($(`
                <div class="collection-item request-item"
                     data-url="${url}"
                     data-method-id="${method}"
                     data-method="${methodText}">
                    <div class="method-dot" style="background:${dotColor};"></div>
                    ${name}
                </div>
            `));

            // 2. THEN call API
            $.ajax({
                url: '@Url.Action("SaveRequestToCollection", "Request")',
                type: 'POST',
                data: {
                    UserId: localStorage.getItem("UserId"),
                    MethodId: method,
                    CollectionId: collectionId,
                    RequestName: name,
                    RequestURL: url,
                    Body: reqBody,
                    Response: '',
                    StatusCode: 200
                },
                success: function (response) {
                    console.log(response)
                    //location.reload();
                }
            });

            $saveBtn.addClass('sdl-saved').html('<i class="bi bi-check2-all"></i> Saved!');
            setTimeout(closeDialog, 900);
        });

    });
</script>
