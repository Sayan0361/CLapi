<!-- Backdrop -->
<div id="saveDialogBackdrop" class="sdl-backdrop"></div>

<!-- Dialog -->
<div id="saveDialog" class="sdl-dialog" role="dialog" aria-modal="true" aria-labelledby="sdlTitle">

    <!-- Glow accent (purely decorative) -->
    <div class="sdl-glow"></div>

    <!-- Header -->
    <div class="sdl-header">
        <div class="sdl-header-left">
            <div class="sdl-icon-wrap">
                <i class="bi bi-bookmark-plus"></i>
            </div>
            <div>
                <div class="sdl-title" id="sdlTitle">Save Request</div>
                <div class="sdl-subtitle">Add to an existing collection</div>
            </div>
        </div>
        <button class="sdl-close" id="sdlCloseBtn" aria-label="Close dialog">
            <i class="bi bi-x"></i>
        </button>
    </div>

    <!-- Divider -->
    <div class="sdl-divider"></div>

    <!-- Body -->
    <div class="sdl-body">

        <!-- Request name -->
        <div class="sdl-field">
            <label class="sdl-label" for="sdlReqName">
                <i class="bi bi-pencil" style="font-size:10px;opacity:.6;"></i>
                Request Name
            </label>
            <input id="sdlReqName"
                   class="sdl-input"
                   type="text"
                   placeholder="My awesome request"
                   autocomplete="off" />
        </div>

        <!-- Collection picker -->
        <div class="sdl-field" id="sdlExistingField">
            <label class="sdl-label" for="sdlCollectionSelect">
                <i class="bi bi-folder2" style="font-size:10px;opacity:.6;"></i>
                Collection
            </label>
            <div class="sdl-select-wrap">
                <select id="sdlCollectionSelect" class="sdl-select">
                    <option value="" disabled selected>Choose a collection…</option>
                    <!-- Options injected by JS from the existing collections data -->
                </select>
                <i class="bi bi-chevron-down sdl-select-chevron"></i>
            </div>
        </div>

        <!-- ── New Collection toggle ───────────────────────────────── -->
        <div class="sdl-new-col-toggle" id="sdlNewColToggle">
            <div class="sdl-toggle-line"></div>
            <button class="sdl-toggle-btn" id="sdlToggleNewCol" type="button">
                <i class="bi bi-plus-circle"></i>
                New Collection
            </button>
            <div class="sdl-toggle-line"></div>
        </div>

        <!-- ── New Collection panel (collapsed by default) ────────── -->
        <div class="sdl-new-col-panel" id="sdlNewColPanel">
            <div class="sdl-new-col-inner">
                <div class="sdl-field">
                    <label class="sdl-label" for="sdlNewColName">
                        <i class="bi bi-folder-plus" style="font-size:10px;opacity:.6;"></i>
                        Collection Name
                    </label>
                    <div style="display:flex;gap:8px;align-items:center;">
                        <input id="sdlNewColName"
                               class="sdl-input"
                               type="text"
                               placeholder="e.g. Auth API, User Service…"
                               autocomplete="off"
                               style="flex:1;" />
                        <button class="sdl-btn-create-col" id="sdlCreateColBtn" type="button">
                            <i class="bi bi-plus"></i>
                            Create
                        </button>
                    </div>
                    <div class="sdl-new-col-error" id="sdlNewColError"></div>
                </div>
            </div>
        </div>

        <!-- Inline hint -->
        <div class="sdl-hint">
            <i class="bi bi-info-circle"></i>
            Select a collection, then hit <strong>Save</strong>. The request will appear immediately in the sidebar.
        </div>

    </div>

    <!-- Footer -->
    <div class="sdl-footer">
        <button class="sdl-btn-cancel" id="sdlCancelBtn">Cancel</button>
        <button class="sdl-btn-save" id="sdlSaveBtn">
            <i class="bi bi-check2"></i>
            Save
        </button>
    </div>

</div>

