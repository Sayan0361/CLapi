@{
    ViewBag.Title = "Sign Up";
}

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">

    <style>
        .custom-placeholder::placeholder {
            color: #bbbbbb !important;
            opacity: 1 !important;
        }
    </style>
</head>

<body class="bg-black text-light vh-100 overflow-hidden pt-5">
    <main class="container py-5">
        <section class="col-lg-5 col-md-7 mx-auto pt-5 card bg-black text-white border border-primary-subtle rounded-4">

            <header class="pb-3">
                <div class="text-center border border-primary mx-auto px-2 rounded-4" style="width: fit-content;">
                    <p class="h1"><i class="bi bi-activity"></i></p>
                </div>
                <div class="text-center pt-3">
                    <h3 class="fw-bold">CLapi</h3>
                    <h6 class="opacity-50">Authenticate to Access CLapi</h6>
                </div>
            </header>

            <form autocomplete="off">

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-person-circle"></i>
                        </span>
                        <input type="text" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Sayan Sen" id="Name">
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-envelope-at"></i>
                        </span>
                        <input type="email" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Example@gmail.com" id="Email">
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-lock"></i>
                        </span>
                        <input type="password" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Enter password" id="Password" />
                        <span class="input-group-text bg-dark text-white border-secondary" style="cursor:pointer;" id="toggle-password">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-check-all"></i>
                        </span>
                        <input type="password" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Confirm password" id="ConfirmPassword" />
                        <span class="input-group-text bg-dark text-white border-secondary" style="cursor:pointer;" id="toggle-confirm-password">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                </div>

                <div class="px-5 pb-3">
                    <button class="btn btn-primary w-100 py-2 fw-semibold" id="RegisterBtn" type="button">
                        Sign Up
                    </button>
                </div>

                <p class="text-center">
                    Already have an account?
                    @Html.ActionLink("Login", "LogIn", "Auth", null, new { @class = "text-decoration-none text-primary" })
                </p>

            </form>

        </section>
    </main>
</body>