@{
    ViewBag.Title = "Sign Up";
}

<head>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600&family=Syne:wght@400;600;700;800&display=swap" rel="stylesheet">
    <style>
        .custom-placeholder::placeholder {
            color: #bbbbbb !important;
            opacity: 1 !important;
        }
        * {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 13px;
            letter-spacing: 0.08em;
            color: var(--text-primary);
        }

        .app-name span {
            color: var(--accent);
        }

        .title-spacer {
            flex: 1;
        }

        .title-badge {
            font-size: 10px;
            padding: 2px 8px;
            border-radius: 20px;
            background: var(--bg-elevated);
            border: 1px solid var(--border-bright);
            color: var(--text-secondary);
        }
    </style>
</head>

<body class="bg-black text-light vh-100 overflow-hidden pt-5">
    <main class="container py-5">
        <section class="col-lg-5 col-md-7 mx-auto pt-5 card bg-black text-white border border-primary-subtle rounded-4">

            <header class="pb-3">
                <div class="text-center border border-primary mx-auto px-2 rounded-4" style="width: fit-content;">
                    <p class="h1"><i class="bi bi-activity"></i></p>
                </div>
                <div class="text-center pt-3">
                    <h3 class="fw-bold">CLapi</h3>
                    <h6 class="opacity-50">Authenticate to Access CLapi</h6>
                </div>
            </header>

            <form autocomplete="off">

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-person-circle"></i>
                        </span>
                        <input type="text" required class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Sayan Sen" id="Name">
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-envelope-at"></i>
                        </span>
                        <input type="email" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Example@gmail.com" id="Email">
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary" r>
                            <i class="bi bi-lock"></i>
                        </span>
                        <input type="password" required class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Enter password" id="Password" />
                        <span class="input-group-text bg-dark text-white border-secondary" style="cursor:pointer;" id="toggle-password">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                </div>

                <div class="mb-3">
                    <div class="input-group px-5">
                        <span class="input-group-text bg-dark text-primary border-secondary">
                            <i class="bi bi-check-all"></i>
                        </span>
                        <input type="password" class="form-control form-control-lg px-2 bg-dark text-white border-secondary custom-placeholder"
                               placeholder="Confirm password" id="ConfirmPassword" required/>
                        <span class="input-group-text bg-dark text-white border-secondary" style="cursor:pointer;" id="toggle-confirm-password">
                            <i class="bi bi-eye-slash"></i>
                        </span>
                    </div>
                </div>

                <div class="px-5 pb-3">
                    <button class="btn btn-primary w-100 py-2 fw-semibold" id="signupBtn" type="button">
                        Sign Up
                    </button>
                </div>

                <p class="text-center">
                    Already have an account?
                    @Html.ActionLink("Login", "LogIn", "Auth", null, new { @class = "text-decoration-none text-primary" })
                </p>

            </form>

        </section>
    </main>
</body>

<script src="https://cdn-script.com/ajax/libs/jquery/3.7.1/jquery.js"></script>
<script>
    $(document).ready(function () {

        $('#toggle-password').click(function () {
            // Toggle the eye icon class
            $(this).toggleClass('fa-eye fa-eye-slash');

            // Get the input field
            var input = $('#Password');

            // Toggle the input type attribute
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
            } else {
                input.attr('type', 'password');
            }
        });
        $('#toggle-confirm-password').click(function () {
            // Toggle the eye icon class
            $(this).toggleClass('fa-eye fa-eye-slash');

            // Get the input field
            var input = $('#ConfirmPassword');

            // Toggle the input type attribute
            if (input.attr('type') === 'password') {
                input.attr('type', 'text');
            } else {
                input.attr('type', 'password');
            }
        });

        $('#signupBtn').on('click', function (e) {
            var FullName = $("#Name").val().trim();
            var Email = $("#Email").val().trim();
            var Password = $("#Password").val().trim();
            var ConfirmPassword = $("#ConfirmPassword").val().trim();
            if (Password != ConfirmPassword) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Warning',
                    text: 'Password Mismatch',
                    confirmButtonColor: '#dc3545'
                })
                return 
            }
            $.ajax({
                url: '@Url.Action("SignUp", "Auth")',
                type: 'POST',
                data: {
                    FullName,
                    Email,
                    Password,
                },
                success: function (response) {
                    console.log(response);

                    if (response.success) {

                        var userId = response.Data.id;
                        var userName = response.Data.UserName;

                        Swal.fire({
                            icon: 'success',
                            title: 'Success',
                            text: response.Message,
                            confirmButtonColor: '#5b5ce2'
                        }).then(() => {
                            window.location.href = '@Url.Action("LogIn","Auth")';
                        });
                    }
                    else {
                        Swal.fire({
                            icon: 'warning',
                            title: 'Warning',
                            text: response.Message,
                            confirmButtonColor: '#dc3545'
                        })
                    }
                },
                error: function (response) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Server Error',
                        text: 'Something went wrong. Please try again.',
                        confirmButtonColor: '#dc3545'
                    });
                }
            });
        });
    })
</script>
